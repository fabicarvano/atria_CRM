# =============================================================================
# .gitignore — Atria CRM
# =============================================================================

# ---------------------------------------------------------------------------
# Credenciais e configuração sensível
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Backups manuais gerados durante o desenvolvimento
# Padrões: *.bak.*, *.bkp*, *.bak
# ---------------------------------------------------------------------------
*.bak
*.bak.*
*.bkp
*.bkp.*
*.bkp-*

# ---------------------------------------------------------------------------
# Logs e diagnósticos temporários
# ---------------------------------------------------------------------------
*.log
logs/
diag_*.txt
typescript

# ---------------------------------------------------------------------------
# Cache e arquivos temporários
# ---------------------------------------------------------------------------
cache/
tmp/
temp/
www/data/cache/
www/data/tmp/
www/client/custom/cache/
www/public/client/custom/cache/

# ---------------------------------------------------------------------------
# Runtime do EspoCRM (gerado automaticamente, não versionar)
# ---------------------------------------------------------------------------
www/data/config.php
www/data/config-internal.php
www/data/state.php
www/data/.data

# ---------------------------------------------------------------------------
# Uploads de usuários e anexos do CRM
# ---------------------------------------------------------------------------
www/data/upload/
www/public/upload/

# ---------------------------------------------------------------------------
# Dependências do Composer (reinstalar com: composer install)
# ---------------------------------------------------------------------------
www/vendor/
vendor/bin/.phpunit/
composer.phar

# ---------------------------------------------------------------------------
# Pasta de backups manuais e snapshots
# ---------------------------------------------------------------------------
backups/
backups_limpeza/
*.sql.gz
*.dump
*.tar
*.tar.gz
*.zip

# Exceção: manter o schema versionado
!schema_banco/
!schema_banco/*.sql

# ---------------------------------------------------------------------------
# Node / front-end
# ---------------------------------------------------------------------------
node_modules/

# ---------------------------------------------------------------------------
# Sistema operacional
# ---------------------------------------------------------------------------
.DS_Store
Thumbbs.db
Thumbbs.db:encryptable
desktop.ini

# ---------------------------------------------------------------------------
# IDEs e editores
# ---------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
*.bak*
*.bak*
www/data/logs/
