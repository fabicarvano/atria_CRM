define('custom:views/account/record/panels/heat-map', ['views/record/panels/bottom'], function (Dep) {

    return Dep.extend({

        templateContent: `
            <div class="heatmap-account-wrapper">
                <div class="heatmap-summary">
                    <div class="heatmap-summary-card">
                        <div class="heatmap-summary-label">% Mapeado</div>
                        <div class="heatmap-summary-value heatmap-percent">0%</div>
                        <div class="heatmap-summary-sub heatmap-percent-sub">0 de 0 aplicáveis</div>
                    </div>

                    <div class="heatmap-summary-card">
                        <div class="heatmap-summary-label">Oportunidades</div>
                        <div class="heatmap-summary-value heatmap-oportunidades">0</div>
                        <div class="heatmap-summary-sub">em andamento</div>
                    </div>

                    <div class="heatmap-summary-card">
                        <div class="heatmap-summary-label">Ofertas da Base</div>
                        <div class="heatmap-summary-value heatmap-base">0</div>
                        <div class="heatmap-summary-sub">Base Atual</div>
                    </div>
                </div>

                <div class="heatmap-grid">
                    <div class="heatmap-card">
                        <div class="heatmap-card-title">Revenda</div>
                        <div class="heatmap-table-wrap">
                            <table class="table table-condensed heatmap-table heatmap-revenda-table">
                                <thead>
                                    <tr>
                                        <th>Oferta</th>
                                        <th>Fornecedor Atual</th>
                                        <th>Status</th>
                                        <th>Concorrente</th>
                                        <th>Observação</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>

                    <div class="heatmap-card">
                        <div class="heatmap-card-title">Serviço Gerenciado</div>
                        <div class="heatmap-table-wrap">
                            <table class="table table-condensed heatmap-table heatmap-servico-table">
                                <thead>
                                    <tr>
                                        <th>Oferta</th>
                                        <th>Fornecedor Atual</th>
                                        <th>Status</th>
                                        <th>Concorrente</th>
                                        <th>Observação</th>
                                    </tr>
                                </thead>
                                <tbody></tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="heatmap-msg text-muted">Carregando Heat Map...</div>
            </div>
        `,

        setup: function () {
            Dep.prototype.setup.call(this);
            this.items = [];
        },

        afterRender: function () {
            Dep.prototype.afterRender.call(this);
            this.injetarCss();
            this.carregarHeatMap();
        },

        injetarCss: function () {
            if ($('#heatmap-account-style').length) {
                return;
            }

            $('head').append(`
                <style id="heatmap-account-style">
                    .heatmap-account-wrapper {
                        padding: 4px 2px 8px;
                    }

                    .heatmap-summary {
                        display: grid;
                        grid-template-columns: repeat(3, minmax(0, 1fr));
                        gap: 12px;
                        margin-bottom: 16px;
                    }

                    .heatmap-summary-card {
                        border: 1px solid #e5e7eb;
                        border-radius: 12px;
                        padding: 14px 16px;
                        background: #fff;
                        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
                    }

                    .heatmap-summary-label {
                        font-size: 12px;
                        color: #64748b;
                        margin-bottom: 4px;
                    }

                    .heatmap-summary-value {
                        font-size: 24px;
                        font-weight: 700;
                        color: #0f172a;
                        line-height: 1.1;
                    }

                    .heatmap-summary-sub {
                        font-size: 11px;
                        color: #94a3b8;
                        margin-top: 4px;
                    }

                    .heatmap-grid {
                        display: grid;
                        grid-template-columns: repeat(2, minmax(0, 1fr));
                        gap: 16px;
                    }

                    .heatmap-card {
                        border: 1px solid #e5e7eb;
                        border-radius: 12px;
                        background: #fff;
                        overflow: hidden;
                        box-shadow: 0 1px 3px rgba(15, 23, 42, 0.06);
                    }

                    .heatmap-card-title {
                        font-weight: 700;
                        padding: 12px 14px;
                        background: #f8fafc;
                        border-bottom: 1px solid #e5e7eb;
                        color: #0f172a;
                    }

                    .heatmap-table-wrap {
                        overflow-x: auto;
                    }

                    .heatmap-table {
                        margin-bottom: 0;
                        font-size: 12px;
                    }

                    .heatmap-table th {
                        color: #64748b;
                        font-weight: 600;
                        white-space: nowrap;
                    }

                    .heatmap-table td {
                        vertical-align: middle !important;
                        white-space: nowrap;
                    }

                    .heatmap-status {
                        display: inline-block;
                        padding: 3px 8px;
                        border-radius: 999px;
                        font-size: 11px;
                        font-weight: 600;
                        background: #f1f5f9;
                        color: #64748b;
                    }

                    .heatmap-status-baseAtual {
                        background: #dcfce7;
                        color: #166534;
                    }

                    .heatmap-status-concorrente {
                        background: #ffedd5;
                        color: #9a3412;
                    }

                    .heatmap-status-oportunidadeEmAndamento {
                        background: #dbeafe;
                        color: #1d4ed8;
                    }

                    .heatmap-status-semAderencia {
                        background: #fef9c3;
                        color: #854d0e;
                    }

                    .heatmap-status-naoSeAplica {
                        background: #e5e7eb;
                        color: #374151;
                    }

                    .heatmap-empty {
                        color: #cbd5e1;
                    }

                    .heatmap-msg {
                        margin-top: 10px;
                        font-size: 12px;
                    }

                    @media (max-width: 1100px) {
                        .heatmap-summary,
                        .heatmap-grid {
                            grid-template-columns: 1fr;
                        }
                    }
                </style>
            `);
        },

        carregarHeatMap: function () {
            var accountId = this.model.id;
            var self = this;

            if (!accountId) {
                this.setMensagem('Conta ainda não salva.');
                return;
            }

            Espo.Ajax.getRequest('MapeamentoConta', {
                where: [
                    {
                        type: 'equals',
                        attribute: 'accountId',
                        value: accountId
                    }
                ],
                maxSize: 200,
                sortBy: 'createdAt',
                asc: true
            }).then(function (response) {
                self.items = response.list || [];
                self.renderizarHeatMap();
            }).catch(function () {
                self.setMensagem('Não foi possível carregar o Heat Map.');
            });
        },

        labelStatus: function (status) {
            var labels = {
                baseAtual: 'Base Atual',
                concorrente: 'Concorrente',
                oportunidadeEmAndamento: 'Oportunidade em andamento',
                semAderencia: 'Sem aderência',
                naoSeAplica: 'Não se aplica'
            };

            return labels[status] || 'Não mapeado';
        },

        valor: function (valor) {
            if (valor === null || valor === undefined || valor === '') {
                return '<span class="heatmap-empty">—</span>';
            }

            return Handlebars.Utils.escapeExpression(String(valor));
        },

        statusHtml: function (status) {
            var label = this.labelStatus(status);
            var classe = status ? 'heatmap-status-' + status : '';

            return '<span class="heatmap-status ' + classe + '">' +
                Handlebars.Utils.escapeExpression(label) +
            '</span>';
        },

        linhaHtml: function (item) {
            var oferta =
                item.catalogoOfertaName ||
                item.name ||
                'Oferta';

            return `
                <tr>
                    <td>${this.valor(oferta)}</td>
                    <td>${this.valor(item.fornecedorAtual)}</td>
                    <td>${this.statusHtml(item.status)}</td>
                    <td>${this.valor(item.concorrenteIdentificado)}</td>
                    <td>${this.valor(item.observacao)}</td>
                </tr>
            `;
        },

        renderizarHeatMap: function () {
            var $revenda = this.$el.find('.heatmap-revenda-table tbody');
            var $servico = this.$el.find('.heatmap-servico-table tbody');

            $revenda.empty();
            $servico.empty();

            var totalAplicavel = 0;
            var totalMapeado = 0;
            var totalOportunidades = 0;
            var totalBase = 0;

            var self = this;

            (this.items || []).forEach(function (item) {
                var status = item.status || '';

                if (status !== 'naoSeAplica') {
                    totalAplicavel++;

                    if (
                        status === 'baseAtual' ||
                        status === 'concorrente' ||
                        status === 'oportunidadeEmAndamento' ||
                        status === 'semAderencia'
                    ) {
                        totalMapeado++;
                    }
                }

                if (status === 'oportunidadeEmAndamento' || item.opportunityId) {
                    totalOportunidades++;
                }

                if (status === 'baseAtual') {
                    totalBase++;
                }

                if (item.categoria === 'servicoGerenciado') {
                    $servico.append(self.linhaHtml(item));
                } else {
                    $revenda.append(self.linhaHtml(item));
                }
            });

            if ($revenda.children().length === 0) {
                $revenda.append('<tr><td colspan="5" class="text-muted">Nenhuma oferta de Revenda encontrada.</td></tr>');
            }

            if ($servico.children().length === 0) {
                $servico.append('<tr><td colspan="5" class="text-muted">Nenhuma oferta de Serviço Gerenciado encontrada.</td></tr>');
            }

            var percentual = totalAplicavel > 0
                ? Math.round((totalMapeado / totalAplicavel) * 100)
                : 0;

            this.$el.find('.heatmap-percent').text(percentual + '%');
            this.$el.find('.heatmap-percent-sub').text(totalMapeado + ' de ' + totalAplicavel + ' aplicáveis');
            this.$el.find('.heatmap-oportunidades').text(totalOportunidades);
            this.$el.find('.heatmap-base').text(totalBase);

            this.setMensagem('');
        },

        setMensagem: function (msg) {
            this.$el.find('.heatmap-msg').text(msg || '');
        }
    });
});
