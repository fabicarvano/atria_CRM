define(['views/fields/base'], function (Dep) {

    return class extends Dep {

        template = 'custom:fields/logo-image';

        setup() {
            super.setup();

            console.log('[LOGO-IMAGE] setup chamado');
            console.log('[LOGO-IMAGE] model attributes:', this.model.attributes);
            console.log('[LOGO-IMAGE] logoUrl no setup:', this.model.get('logoUrl'));
        }

        data() {
            const logoUrl = this.model.get('logoUrl') || null;
            const name = this.model.get('name') || '';

            const initials = name
                .trim()
                .split(/\s+/)
                .slice(0, 2)
                .map(word => word[0])
                .join('')
                .toUpperCase() || '?';

            console.log('[LOGO-IMAGE] data chamado');
            console.log('[LOGO-IMAGE] logoUrl:', logoUrl);
            console.log('[LOGO-IMAGE] initials:', initials);

            return {
                logoUrl: logoUrl,
                initials: initials
            };
        }

        afterRender() {
            super.afterRender();

            console.log('[LOGO-IMAGE] afterRender chamado');
            console.log('[LOGO-IMAGE] HTML renderizado:', this.$el.html());
        }
    };
});
